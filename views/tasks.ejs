<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Tasks | Task Manager</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="topbar">
    <h1>Task Manager</h1>
    <div class="topbar-right">
      <span class="muted">Hi, <%= user.username %></span>
      <form method="POST" action="/logout" class="inline">
        <button type="submit" class="link">Logout</button>
      </form>
    </div>
  </header>

  <main class="container">
    <section class="card">
      <h2>New task</h2>
      <form id="new-task-form" class="task-form">
        <input name="title" placeholder="Title" required>
        <input name="description" placeholder="Description (optional)">
        <input name="due_date" type="date">
        <button type="submit" class="primary">Add</button>
      </form>
      <div id="new-task-status" class="muted small"></div>
    </section>

    <section class="card">
      <h2>Your tasks (<span id="task-count"><%= tasks.length %></span>)</h2>
      <p id="empty-msg" class="muted"<% if (tasks.length > 0) { %> hidden<% } %>>No tasks yet. Add one above.</p>
      <ul class="task-list" id="task-list">
        <% tasks.forEach(function(t) { %>
          <li class="task <%= t.status === 'done' ? 'task-done' : '' %>" data-task-id="<%= t.id %>">
            <div class="task-main">
              <form method="POST" action="/tasks/<%= t.id %>/toggle" class="inline">
                <button type="submit" class="toggle" aria-label="Toggle status">
                  <%= t.status === 'done' ? '☑' : '☐' %>
                </button>
              </form>
              <div class="task-body">
                <strong><%= t.title %></strong>
                <div class="desc-view" data-task-id="<%= t.id %>">
                  <span class="muted desc-text <%= t.description ? '' : 'desc-empty' %>">
                    <% if (t.description) { %><%= t.description %><% } else { %><em>No description</em><% } %>
                  </span>
                  <button type="button" class="link small edit-desc-btn" data-task-id="<%= t.id %>">Edit</button>
                </div>
                <div class="desc-edit hidden" data-task-id="<%= t.id %>">
                  <textarea class="desc-input" rows="2"><%= t.description || '' %></textarea>
                  <div class="desc-edit-actions">
                    <button type="button" class="primary small save-desc-btn" data-task-id="<%= t.id %>">Save</button>
                    <button type="button" class="small cancel-desc-btn" data-task-id="<%= t.id %>">Cancel</button>
                    <span class="desc-status muted small" data-task-id="<%= t.id %>"></span>
                  </div>
                </div>
                <% if (t.due_date) { %><div class="muted small">Due: <%= t.due_date %></div><% } %>
              </div>
            </div>
            <div class="task-actions">
              <span class="badge"><%= t.status %></span>
              <button type="button" class="danger delete-task-btn" data-task-id="<%= t.id %>">Delete</button>
            </div>
          </li>
        <% }); %>
      </ul>
    </section>
  </main>
  <script src="/app.js"></script>
</body>
</html>
